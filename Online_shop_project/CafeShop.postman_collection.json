    {
      "name": "👤 Customer – Ana Jovanovic",
      "description": "Kompletan tok kupca. Pokrenite '01 – Login' i token će se sačuvati i automatski koristiti u svim ostalim zahtevima u folderu.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const token = pm.collectionVariables.get('token');",
              "if (token && token.trim() !== '') {",
              "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
              "}"
            ]
          }
        }
      ],
      "item": [

        {
          "name": "01 – Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('customerId', res.id);",
                  "pm.collectionVariables.set('token', res.token);",
                  "pm.test('Login uspešan – status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Vraća ID korisnika', () => pm.expect(res.id).to.be.a('number'));",
                  "pm.test('Vraća JWT token', () => pm.expect(res.token).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ana.jovanovic@example.com\",\n  \"password\": \"123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/user-service/api/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["user-service", "api", "users", "login"]
            }
